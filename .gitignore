# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files
# 기본 환경변수 파일
.env
# .env.production, .env.staging 등 모든 변형 
.env.*
# 예시 템플릿은 예외로 추적       
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Except settings.json
!.vscode/settings.json